########################################################
## 2) Profiles - إكمال البيانات
########################################################

### Complete Patient Profile (مع رفع صور)
# ملاحظة: تأكد من وجود الملفات nid_image.jpg و social_proof.jpg في مجلد R3AIA
POST {{host}}/api/Profiles/patient
Authorization: Bearer {{patientToken}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="FullName"

shendico1
--boundary
Content-Disposition: form-data; name="PhoneNumber"

01099999999
--boundary
Content-Disposition: form-data; name="GovernorateId"

1
--boundary
Content-Disposition: form-data; name="CityId"

1
--boundary
Content-Disposition: form-data; name="Address"

cairo
--boundary
Content-Disposition: form-data; name="HasChronicDisease"

false
--boundary
Content-Disposition: form-data; name="NIDImage"; filename="nid_image.jpg"
Content-Type: image/jpeg

< ./nid_image.jpg
--boundary
Content-Disposition: form-data; name="SocialProofImage"; filename="social_proof.jpg"
Content-Type: image/jpeg

< ./social_proof.jpg
--boundary--

### Complete Doctor Profile
POST {{host}}/api/Profiles/doctor
Authorization: Bearer {{doctorToken}}
Content-Type: {{contentType}}

{
  "fullName": "Doctor jo",
  "phoneNumber": "01234567890",
  "specialtyId": {{specId}},
  "governorateId": 1,
  "cityId": 1,
  "clinicAddress": "Clinic Address"
}

### Complete Pharmacy Profile
POST {{host}}/api/Profiles/pharmacy
Authorization: Bearer {{pharmacyToken}}
Content-Type: {{contentType}}

{
  "pharmacyName": "Test Pharmacy",
  "phoneNumber": "01000000002",
  "governorateId": 1,
  "cityId": 1,
  "address": "Pharmacy address"
}

### Complete Volunteer Profile
POST {{host}}/api/Profiles/volunteer
Authorization: Bearer {{volunteerToken}}
Content-Type: {{contentType}}

{
  "fullName": "ali",
  "nationalID": "30002021260202022",
  "phoneNumber": "01000000003",
  "governorateId": 1
}

### Admin Verify User (To allow medicine requests)
POST {{host}}/api/Admin/verify-user
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}

{
  "userId": "{{reportedUserId}}",
  "isApproved": true
}

########################################################
## 3) Medicine Requests (Pharmacy & Delivery)
########################################################

### Create Medicine Request (Patient)
# ملاحظة: يجب وجود ملف باسم prescription.jpg في نفس المجلد
POST {{host}}/api/MedicineRequests
Authorization: Bearer {{patientToken}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="PrescriptionImage"; filename="prescription.jpg"
Content-Type: image/jpeg

< ./prescriptio1n.jpg
--boundary
Content-Disposition: form-data; name="NeedDelivery"

true
--boundary--

### Get Open Medicine Requests (Pharmacy)
GET {{host}}/api/MedicineRequests/open
Authorization: Bearer {{pharmacyToken}}

### Accept Medicine Request (Pharmacy)
POST {{host}}/api/MedicineRequests/accept/{{medicineRequestId}}
Authorization: Bearer {{pharmacyToken}}
Content-Type: {{contentType}}

{
  "pharmacyNotes": "الدواء جاهز للاستلام من الساعة 9 صباحاً"
}

### Get My Medicine Requests (Patient)
GET {{host}}/api/MedicineRequests/my-requests
Authorization: Bearer {{patientToken}}

### Get Delivery Tasks (Volunteer)
# يعرض مهام التوصيل المتاحة (التي لم يتم أخذها بعد)
# بعد التعديل: يستثني الطلبات الموجودة في جدول DeliveryTasks
GET {{host}}/api/MedicineRequests/delivery-tasks
Authorization: Bearer {{volunteerToken}}

### Take Delivery Task (Volunteer)
# يأخذ مهمة توصيل
# بعد التعديل: ينشئ سطر جديد في جدول DeliveryTasks
# افحص جدول DeliveryTasks بعد تنفيذ هذا الطلب: SELECT * FROM DeliveryTasks
POST {{host}}/api/MedicineRequests/take-delivery/{{medicineRequestId}}
Authorization: Bearer {{volunteerToken}}

### Mark As Delivered (Volunteer)
# يؤكد إتمام التوصيل
# بعد التعديل: يحدث DeliveryTask.TaskStatus إلى Delivered
# افحص جدول DeliveryTasks: TaskStatus يجب أن تكون 2 (Delivered)
POST {{host}}/api/MedicineRequests/mark-delivered/{{medicineRequestId}}
Authorization: Bearer {{volunteerToken}}

########################################################
## 4) Medical Requests (Doctor & Patient)
########################################################

### Create Medical Request (Patient)
POST {{host}}/api/MedicalRequests/create
Authorization: Bearer {{patientToken}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="Description"

عندي ألم شديد في البطن
--boundary
Content-Disposition: form-data; name="SpecialtyId"

{{specId}}
--boundary
Content-Disposition: form-data; name="MedicalImages"; filename="xray.jpg"
Content-Type: image/jpeg

< ./xray.jpg
--boundary--

### Get Medical Requests for Doctor
GET {{host}}/api/MedicalRequests/for-doctor
Authorization: Bearer {{doctorToken}}

### Get Medical Request Detail (Doctor)
GET {{host}}/api/MedicalRequests/detail/{{medRequestId}}
Authorization: Bearer {{doctorToken}}

### Respond to Medical Request (Doctor)
POST {{host}}/api/MedicalRequests/respond/{{medRequestId}}
Authorization: Bearer {{doctorToken}}
Content-Type: {{contentType}}

{
  "appointmentDate": "2026-02-15T14:00:00",
  "doctorNotes": "يرجى الحضور في الموعد المحدد."
}

### Get My Medical Requests (Patient)
GET {{host}}/api/MedicalRequests/my-requests
Authorization: Bearer {{patientToken}}

### Cancel Request (Patient)
POST {{host}}/api/MedicalRequests/cancel/{{medRequestId}}
Authorization: Bearer {{patientToken}}
Content-Type: {{contentType}}

{
  "cancellationReason": "تحسنت حالتي"
}

### Cancel Request (Doctor)
POST {{host}}/api/MedicalRequests/cancel-by-doctor/{{medRequestId}}
Authorization: Bearer {{doctorToken}}
Content-Type: {{contentType}}

{
  "cancellationReason": "ظرف طارئ"
}

########################################################
## 5) Donations & Support
########################################################

### Get Donation Cases
GET {{host}}/api/Donations/cases

### Pay Donation
POST {{host}}/api/Donations/pay
Authorization: Bearer {{patientToken}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="CaseId"

{{caseId}}
--boundary
Content-Disposition: form-data; name="Amount"

100
--boundary
Content-Disposition: form-data; name="ReceiptImage"; filename="receipt.jpg"
Content-Type: image/jpeg

< ./receipt.jpg
--boundary--

### Create Support Report
POST {{host}}/api/Support/report
Authorization: Bearer {{patientToken}}
Content-Type: {{contentType}}

{
  "reportedUserId": "{{reportedUserId}}",
  "reason": "Inappropriate behavior"
}

### Get My Notifications
GET {{host}}/api/Support/notifs
Authorization: Bearer {{patientToken}}

########################################################
## 6) Admin Monitoring & Control
########################################################

### Get Stalled Requests
GET {{host}}/api/Admin/stalled-requests?minutes=60
Authorization: Bearer {{adminToken}}

### Create Donation Case (Admin)
POST {{host}}/api/Admin/create-case
Authorization: Bearer {{adminToken}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="Title"

New Surgery Case
--boundary
Content-Disposition: form-data; name="Description"

Critical condition
--boundary
Content-Disposition: form-data; name="GoalAmount"

10000
--boundary
Content-Disposition: form-data; name="CaseImage"; filename="case.jpg"
Content-Type: image/jpeg

< ./case.jpg
--boundary--

### Resolve Report (Admin)
PUT {{host}}/api/Admin/resolve-report
Authorization: Bearer {{adminToken}}
Content-Type: {{contentType}}

{
  "reportId": {{reportId}},
  "adminComment": "Resolved."
}

### Ban User
POST {{host}}/api/Admin/ban-user/{{banUserId}}
Authorization: Bearer {{adminToken}}

### Unban User
POST {{host}}/api/Admin/unban-user/{{banUserId}}
Authorization: Bearer {{adminToken}}
